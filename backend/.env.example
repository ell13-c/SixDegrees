# backend/.env.example

# Supabase Configuration (Backend)
# Get these from: https://app.supabase.com → Your Project → Settings → API

SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your-service-role-key-here

# Database URL (if using direct PostgreSQL connection)
DATABASE_URL=postgresql://postgres:[password]@db.[project-id].supabase.co:5432/postgres

GLOBAL_COMPUTE_ENABLED=false

# CORS allowed origins (comma-separated). Defaults to localhost for development.
# In production, set this to your deployed frontend URL:
# ALLOWED_ORIGINS=https://your-frontend.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173